---
import BaseLayout from "./BaseLayout.astro";
const { frontmatter } = Astro.props;
---
<BaseLayout pageTitle={frontmatter.title}>
  <p>{frontmatter.pubDate.toLocaleDateString()}</p>
  <p><em>{frontmatter.description}</em></p>

  <p>Written by: {frontmatter.author}</p>
  
  <img src={frontmatter.image.url} width="500" alt={frontmatter.image.alt} class="post-image clickable-image" />

  <slot />

  <!-- 라이트박스 모달 -->
  <div id="lightbox" class="lightbox">
    <span class="lightbox-close">&times;</span>
    <img id="lightbox-image" class="lightbox-content" alt="" />
  </div>

  <div class="tags">
    {frontmatter.tags.map((tag: string) => (
    <p class="tag"><a href={`/tags/${tag}`}>{tag}</a></p>
    ))}
  </div>

</BaseLayout>
<style>
  a {
    color: #00539F;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
  }

  .tag {
    margin: 0.25em;
    border: dotted 1px #a1a1a1;
    border-radius: .5em;
    padding: .5em 1em;
    font-size: 1.15em;
    background-color: #F8FCFD;
  }

  .post-image {
    width: 500px;
    height: auto;
  }

  .clickable-image {
    cursor: pointer;
    transition: opacity 0.2s ease;
  }

  .clickable-image:hover {
    opacity: 0.8;
  }

  /* 마크다운 콘텐츠 내의 모든 이미지 */
  :global(img) {
    max-width: 100%;
    height: auto;
  }

  :global(.markdown-image) {
    cursor: pointer;
    transition: opacity 0.2s ease;
  }

  :global(.markdown-image:hover) {
    opacity: 0.8;
  }

  /* 라이트박스 스타일 */
  .lightbox {
    display: none;
    position: fixed;
    z-index: 1000;
    left: 0;
    top: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, 0.8);
    animation: fadeIn 0.3s ease;
  }

  .lightbox.active {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .lightbox-content {
    max-width: 90%;
    max-height: 90vh;
    object-fit: contain;
    animation: zoomIn 0.3s ease;
  }

  .lightbox-close {
    position: absolute;
    top: 20px;
    right: 30px;
    color: white;
    font-size: 40px;
    font-weight: bold;
    cursor: pointer;
    transition: color 0.2s ease;
  }

  .lightbox-close:hover {
    color: #bbb;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  @keyframes zoomIn {
    from {
      transform: scale(0.8);
      opacity: 0;
    }
    to {
      transform: scale(1);
      opacity: 1;
    }
  }

  @media screen and (max-width: 768px) {
    .post-image {
      width: 100%;
    }
  }
</style>

<script>
  function setupLightbox() {
    const lightbox = document.getElementById('lightbox');
    const lightboxImage = document.getElementById('lightbox-image') as HTMLImageElement;
    const lightboxClose = document.querySelector('.lightbox-close');

    // 포스트 이미지 클릭
    const clickableImages = document.querySelectorAll('.clickable-image');
    clickableImages.forEach((img) => {
      img.addEventListener('click', () => {
        const imgElement = img as HTMLImageElement;
        if (lightboxImage) {
          lightboxImage.src = imgElement.src;
          lightboxImage.alt = imgElement.alt;
          lightbox?.classList.add('active');
        }
      });
    });

    // 마크다운 내의 모든 이미지 클릭 (clickable-image 제외)
    const allImages = document.querySelectorAll('img:not(.clickable-image)');
    allImages.forEach((img) => {
      // 레이아웃이나 컴포넌트의 이미지는 제외
      if (!img.closest('header') && !img.closest('footer') && !img.closest('nav')) {
        img.classList.add('markdown-image');
        img.addEventListener('click', () => {
          const imgElement = img as HTMLImageElement;
          if (lightboxImage) {
            lightboxImage.src = imgElement.src;
            lightboxImage.alt = imgElement.alt;
            lightbox?.classList.add('active');
          }
        });
      }
    });

    // 닫기 버튼 클릭
    lightboxClose?.addEventListener('click', () => {
      lightbox?.classList.remove('active');
    });

    // 배경 클릭
    lightbox?.addEventListener('click', (e) => {
      if (e.target === lightbox) {
        lightbox.classList.remove('active');
      }
    });

    // ESC 키
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        lightbox?.classList.remove('active');
      }
    });
  }

  // 페이지 로드 후 실행
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', setupLightbox);
  } else {
    setupLightbox();
  }
</script>