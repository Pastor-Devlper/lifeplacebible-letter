---
const { url, title, image, pubDate } = Astro.props;
const formattedDate = new Date(pubDate).toLocaleDateString('ko-KR', {
  year: 'numeric',
  month: '2-digit',
  day: '2-digit'
});
---
<li>
  <a href={url} class="post-card">
    {image?.url ? <img src={image.url} alt={image.alt ?? title} /> : null}
    <div class="post-card-body">
      <div class="post-card-header">
        <h3>{title}</h3>
        <p class="post-date">{formattedDate}</p>
      </div>
    </div>
  </a>
</li>

<style>
  .post-card {
    display: flex;
    flex-direction: column;
    height: 100%;
    border-radius: 1rem;
    overflow: hidden;
    background-color: #ffffff;
    box-shadow: 0 12px 30px rgba(15, 23, 42, 0.08);
    color: inherit;
    text-decoration: none;
    transition: transform 0.18s ease, box-shadow 0.18s ease;
  }

  .post-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 18px 40px rgba(15, 23, 42, 0.14);
  }

  .post-card img {
    width: 100%;
    aspect-ratio: 4/3;
    object-fit: cover;
    display: block;
  }

  .post-card-body {
    padding: 1rem;
    flex: 0 0 auto;
    display: flex;
    align-items: center;
    background-color: #ffffff;
  }

  .post-card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    gap: 1rem;
  }

  .post-card h3 {
    margin: 0;
    font-size: 1.1rem;
    line-height: 1.4;
    color: #0d0950;
    flex: 1;
  }

  .post-date {
    margin: 0;
    font-size: 0.85rem;
    font-weight: 300;
    font-style: italic;
    color: #666;
    white-space: nowrap;
    flex-shrink: 0;
  }
</style>