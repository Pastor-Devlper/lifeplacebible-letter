    justify-content: center;
    padding: 0.5rem 1rem;
    color: white;
    background-color: #4c1d95;
    text-decoration: none;
  }
</style>

<footer>
  <a href="https://info.ahaja.org" target="_blank" rel="noopener noreferrer" class="social-button" aria-label="생터성경사역원">
    생터홈페이지
  </a>
  <Social platform="instagram" username="ahaja_official" />
  <Social platform="youtube" username="@생터성경사역원" />
</footer>